POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=producthunter

TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_API_KEY=replace-with-strong-typesense-key

# Pipeline: server (production) DB — the main producthunt application DB
SERVER_DB_URL=postgresql://postgres:postgres@localhost:5432/producthunter

# Pipeline: staging DB (same Postgres instance, separate database)
STAGING_DB_URL=postgresql://postgres:postgres@localhost:5432/producthunter

# Pipeline: LLM provider
LLM_PROVIDER=openai
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_BASE_URL=http://localhost:8080/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_TIMEOUT_SECONDS=120
OPENAI_MAX_OUTPUT_TOKENS=4096

# Pipeline: LiteRTLM self-hosted LLM gateway (legacy fallback; set LLM_PROVIDER=litertlm)
LITELLM_BASE_URL=http://localhost:8080
LITELLM_API_KEY=lrtlm_replace_with_your_api_key
